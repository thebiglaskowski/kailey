---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Kailey Blakely"
  description="The page you're looking for doesn't exist."
>
  <section class="container-prose py-24 md:py-32 text-center">
    <p class="text-sm font-medium text-tan uppercase tracking-wide mb-3">404</p>
    <h1 class="text-5xl md:text-6xl font-serif text-sage-deep mb-4">Page not found.</h1>
    <p class="text-lg text-ink-soft mb-10 max-w-xl mx-auto">
      The page you're looking for has wandered off. Let's get you back on track.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="btn-primary">Back to Home &rarr;</a>
      <a href="/work" class="btn-secondary">View the Work</a>
    </div>
  </section>
</BaseLayout>
